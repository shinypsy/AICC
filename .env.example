# OpenAI (3단계 RAG에서 사용)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# 서버
PORT=8000

# Whisper STT (오픈소스)
# tiny | base | small | medium | large-v3
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
# cpu면 int8, GPU(cuda)면 float16 권장
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ko

# TTS (오픈소스 Meta MMS)
TTS_ENABLED=1
TTS_MODEL=facebook/mms-tts-kor

# AI 페르소나 (RAG)
AI_SYSTEM_PROMPT=당신은 AICC 테스트 상담원입니다. 한국어로 짧고 명확하게 답하세요.

# --- 선택: Twilio 일반전화 (twilio_voice.py) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
PUBLIC_BASE_URL=
